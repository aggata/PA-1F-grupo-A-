        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Digite um número: -8\n",
            "O número é negativo\n"
          ]
        }
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "7.\tCalculadora simples\n",
        "Peça dois números e uma operação (+, -, *, /). Use if/elif para calcular o resultado\n"
      ],
      "metadata": {
        "id": "_k5PzvSwJvbE"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Entrada\n",
        "num1 = float(input(\"Digite o primeiro número: \"))\n",
        "operacao = input(\"Digite a operação (+, -, *, /): \")\n",
        "num2 = float(input(\"Digite o segundo número: \"))\n",
        "\n",
        "# Processamento\n",
        "resultado = None\n",
        "\n",
        "if operacao == \"+\":\n",
        "  print(num1 + num2)\n",
        "\n",
        "elif operacao == \"-\":\n",
        "  print(num1 - num2)\n",
        "\n",
        "elif operacao == \"*\":\n",
        "  print(num1 * num2)\n",
        "\n",
        "elif operacao == \"/\":\n",
        "  print(num1 / num2)\n",
        "\n",
        "else:\n",
        "  print(\"Operação inválida\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "Bele7nn6Jz5t",
        "outputId": "9a1f1fd8-7a72-4b32-9a32-b1819a7bf884"
      },
      "execution_count": 61,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Digite o primeiro número: 8\n",
            "Digite a operação (+, -, *, /): /\n",
            "Digite o segundo número: 8\n",
            "1.0\n"
          ]
        }
      ]
    },
