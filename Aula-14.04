        "9.\tAno bissexto\n",
        "Solicite um ano e informe se ele é bissexto ou não.\n"
      ],
      "metadata": {
        "id": "UStMByu3Lqv5"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Entrada\n",
        "ano = int(input(\"Digite um ano: \"))\n",
        "\n",
        "# Processamento\n",
        "if (ano % 4 == 0 and ano % 100 != 0) or ano% 400 == 0:\n",
        "  print(\"O ano é bissexto\")\n",
        "\n",
        "elif ano % 4 != 0:\n",
        "  print(\"O ano não é bissexto\")\n",
        "\n",
        "else:\n",
        "  print(\"O ano não é bissexto\")\n"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
