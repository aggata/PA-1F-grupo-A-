      "source": [
        "10.\tDesconto em compras\n",
        "Peça o valor de uma compra:\n",
        "•\t≥ 100: 10% de desconto\n",
        "•\t≥ 50 e < 100: 5% de desconto\n",
        "•\t< 50: sem desconto\n"
      ],
      "metadata": {
        "id": "igV2H7c-RxS9"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Entrada\n",
        "valor = float(input(\"Digite o valor da compra: \"))\n",
        "desconto = 0\n",
        "\n",
        "# Processamento\n",
        "if valor >= 100:\n",
        "    desconto = 0.10\n",
        "    print(\"O valor do desconto é: \", desconto)\n",
        "elif valor >= 50 and valor < 100:\n",
        "    desconto = 0.05\n",
        "    print(\"O valor do desconto é: \", desconto)\n",
        "\n",
        "else:\n",
        "    desconto = 0\n",
        "\n",
        "valor_final = valor * (1 - desconto)\n",
        "print(f\"Valor da compra: R$ {valor: .2f}\")\n",
        "print(f\"Desconto aplicado: {desconto * 100: .0f}%\")\n",
        "print(f\"Valor final com desconto: R$ {valor_final: .2f}\")\n"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "9e_jCZBQR0tM",
        "outputId": "9693eef6-2025-4f84-83e0-df82ed5d849c"
      },
      "execution_count": 81,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
